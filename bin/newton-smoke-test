#!/usr/bin/env bash
#
# Newton-owned end-to-end smoke test for the judge0 API.
#
# Submits a hello-world program for every active language id in
# db/languages/active.rb to a running judge0 instance and verifies that:
#   - the API accepts the submission
#   - workers pick it up
#   - the sandbox compiles + runs to "Accepted" status
#   - stdout contains the expected marker
#
# Usage:
#   ./bin/newton-smoke-test                  # against http://localhost:2358
#   JUDGE0_URL=http://other:2358 ./bin/newton-smoke-test
#
# Prerequisites: jq, curl, a running judge0 stack with at least one Resque
# worker draining the queue.
#
# Exits non-zero if any language fails. Intentionally tolerant of a few
# languages that need bespoke source (HDL, Jack, Multi-file, Executable);
# those are SKIPped with a reason.

set -u

URL="${JUDGE0_URL:-http://localhost:2358}"
EXPECTED="Hello, Newton!"
# Detect TARGET architecture (where submissions execute) via /system_info,
# not the local machine — running this from an arm64 Mac against an amd64
# server should not skip NASM/FreeBASIC.
ARCH="$(curl -fsS "${URL}/system_info" 2>/dev/null | jq -r '.Architecture // empty')"
ARCH="${ARCH:-$(uname -m)}"

PASS=0
FAIL=0
SKIP=0
FAILED=()
SKIPPED=()

if ! command -v jq >/dev/null; then
    echo "ERROR: jq is required (brew install jq / apt-get install jq)" >&2
    exit 2
fi

echo "Submitting against ${URL} (arch=${ARCH})"
echo

# t <name> <language_id> <source_code>  [<expected_substring>]
t() {
    local name="$1" lid="$2" src="$3"
    local expected="${4:-$EXPECTED}"
    local payload resp status stdout err
    payload="$(jq -nc --arg sc "$src" --argjson lid "$lid" \
        '{language_id:$lid, source_code:$sc}')"
    resp="$(curl -s -X POST "${URL}/submissions?wait=true&fields=stdout,stderr,status,message,compile_output" \
        -H 'Content-Type: application/json' -d "$payload")"
    _check_resp "$name" "$lid" "$expected" "$resp"
}

# t_mem <name> <language_id> <source_code> <memory_limit_kb> [<expected_substring>]
# Same as t() but pins an explicit memory_limit on the submission. Used for
# languages whose compile step needs more than the global default — Kotlin's
# kotlinc bootstrap blows past 128 MB and gets OOM-killed by the cgroup
# unless we ask for headroom.
t_mem() {
    local name="$1" lid="$2" src="$3" mem="$4"
    local expected="${5:-$EXPECTED}"
    local payload resp
    payload="$(jq -nc --arg sc "$src" --argjson lid "$lid" --argjson mem "$mem" \
        '{language_id:$lid, source_code:$sc, memory_limit:$mem}')"
    resp="$(curl -s -X POST "${URL}/submissions?wait=true&fields=stdout,stderr,status,message,compile_output" \
        -H 'Content-Type: application/json' -d "$payload")"
    _check_resp "$name" "$lid" "$expected" "$resp"
}

# t_stdin <name> <language_id> <source_code> <stdin> <expected_substring>
# Same as t() but also sends a stdin payload — used by HDL where the test
# script lives in stdin and the chip definition lives in source_code.
t_stdin() {
    local name="$1" lid="$2" src="$3" stdin="$4" expected="$5"
    local payload resp
    payload="$(jq -nc --arg sc "$src" --arg si "$stdin" --argjson lid "$lid" \
        '{language_id:$lid, source_code:$sc, stdin:$si}')"
    resp="$(curl -s -X POST "${URL}/submissions?wait=true&fields=stdout,stderr,status,message,compile_output" \
        -H 'Content-Type: application/json' -d "$payload")"
    _check_resp "$name" "$lid" "$expected" "$resp"
}

# t_stdin_with_asset <name> <language_id> <source_code> <stdin> <expected_substring> <asset_logical_name>
# Phase 3 — same as t_stdin, but also asserts the named asset is captured:
#   1. submission GET (with fields=...,assets) returns metadata with size_bytes>0 and error=null
#   2. dedicated bytes endpoint returns HTTP 200
# Adds an additional PASS/FAIL row beyond the stdout grading check, so a
# Verilog problem with $dumpfile contributes 2 entries to the smoke summary.
t_stdin_with_asset() {
    local name="$1" lid="$2" src="$3" stdin="$4" expected="$5" asset_name="$6"
    local payload resp token assets_json size err bytes_status

    payload="$(jq -nc --arg sc "$src" --arg si "$stdin" --argjson lid "$lid" \
        '{language_id:$lid, source_code:$sc, stdin:$si}')"
    resp="$(curl -s -X POST "${URL}/submissions?wait=true&fields=token,stdout,stderr,status,message,compile_output,assets" \
        -H 'Content-Type: application/json' -d "$payload")"

    token="$(echo "$resp" | jq -r '.token // empty')"
    _check_resp "$name" "$lid" "$expected" "$resp"

    if [[ -z "$token" ]]; then
        printf "  \033[31mFAIL\033[0m  %s asset (no token returned)\n" "$name"
        FAIL=$((FAIL+1))
        FAILED+=("$name asset (no token)")
        return
    fi

    assets_json="$(echo "$resp" | jq -c --arg n "$asset_name" '.assets // [] | map(select(.logical_name == $n)) | .[0] // {}')"
    size="$(echo "$assets_json" | jq -r '.size_bytes // 0')"
    err="$(echo "$assets_json" | jq -r '.error // empty')"

    if [[ -n "$err" || "$size" -le 0 ]]; then
        printf "  \033[31mFAIL\033[0m  %s asset metadata  size=%s err=%s\n" "$name" "$size" "$err"
        FAIL=$((FAIL+1))
        FAILED+=("$name asset metadata (size=$size err=$err)")
        return
    fi

    bytes_status="$(curl -s -o /dev/null -w '%{http_code}' "${URL}/submissions/$token/assets/$asset_name")"
    if [[ "$bytes_status" != "200" ]]; then
        printf "  \033[31mFAIL\033[0m  %s asset bytes endpoint http=%s\n" "$name" "$bytes_status"
        FAIL=$((FAIL+1))
        FAILED+=("$name asset bytes (http $bytes_status)")
        return
    fi

    printf "  \033[32mPASS\033[0m  %s asset (size=%s)\n" "$name" "$size"
    PASS=$((PASS+1))
}

_check_resp() {
    local name="$1" lid="$2" expected="$3" resp="$4"
    local status stdout err
    status="$(echo "$resp" | jq -r '.status.description // "?"')"
    stdout="$(echo "$resp" | jq -r '.stdout // ""')"
    if [[ "$status" == "Accepted" && "$stdout" == *"$expected"* ]]; then
        printf "  \033[32mPASS\033[0m  %s\n" "$name"
        PASS=$((PASS+1))
    else
        printf "  \033[31mFAIL\033[0m  %s  status=%s\n" "$name" "$status"
        if [[ -n "$stdout" ]]; then
            printf "        stdout: %s\n" "$(echo "$stdout" | head -1)"
        fi
        err="$(echo "$resp" | jq -r '.compile_output // .stderr // .message // empty' | head -3 | tr '\n' ' ')"
        [[ -n "$err" ]] && printf "        err: %s\n" "$err"
        FAIL=$((FAIL+1))
        FAILED+=("$name (id $lid, $status)")
    fi
}

skip() {
    local name="$1" reason="$2"
    printf "  \033[33mSKIP\033[0m  %s  (%s)\n" "$name" "$reason"
    SKIP=$((SKIP+1))
    SKIPPED+=("$name: $reason")
}

section() { printf "\n\033[1m== %s ==\033[0m\n" "$1"; }

# ────────────────────────────────────────────────────────────────────────
# Source snippets — one per active language.
# ────────────────────────────────────────────────────────────────────────
SRC_BASH='echo "Hello, Newton!"'

SRC_C='#include <stdio.h>
int main(void) { printf("Hello, Newton!\n"); return 0; }'

SRC_CPP='#include <iostream>
int main() { std::cout << "Hello, Newton!" << std::endl; return 0; }'

SRC_JAVA='public class Main {
    public static void main(String[] a) {
        System.out.println("Hello, Newton!");
    }
}'

SRC_KOTLIN='fun main() { println("Hello, Newton!") }'

SRC_SCALA='object Main { def main(args: Array[String]): Unit = println("Hello, Newton!") }'

SRC_CSHARP='using System;
class Program {
    static void Main() {
        Console.WriteLine("Hello, Newton!");
    }
}'

# Plain text — submission body is dumped verbatim by /bin/cat.
SRC_PLAIN_TEXT='Hello, Newton!'

SRC_GO='package main
import "fmt"
func main() { fmt.Println("Hello, Newton!") }'

SRC_RUST='fn main() { println!("Hello, Newton!"); }'

SRC_R='cat("Hello, Newton!\n")'

SRC_PYTHON='print("Hello, Newton!")'

SRC_PYTHON_ML='import os
os.environ["OPENBLAS_NUM_THREADS"] = "1"
print("Hello, Newton!")'

SRC_RUBY='puts "Hello, Newton!"'

SRC_TS='console.log("Hello, Newton!");'

SRC_NODE='console.log("Hello, Newton!")'

SRC_SQL="SELECT 'Hello, Newton!';"

SRC_FBC='print "Hello, Newton!"'

# x86_64 Linux syscall hello world
SRC_NASM='section .data
    msg db "Hello, Newton!", 10
    len equ $ - msg
section .text
global _start
_start:
    mov rax, 1
    mov rdi, 1
    mov rsi, msg
    mov rdx, len
    syscall
    mov rax, 60
    xor rdi, rdi
    syscall'

# MIPS hello world for MARS simulator (uses syscall convention)
SRC_MIPS='        .data
msg:    .asciiz "Hello, Newton!\n"
        .text
main:
        li      $v0, 4
        la      $a0, msg
        syscall
        li      $v0, 10
        syscall'

# HDL: a 2-input Mux chip (idempotent, easy to verify against truth table).
# stdin carries the .tst script that drives the simulator.
SRC_HDL='CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
    Not(in=sel, out=notSel);
    And(a=a, b=notSel, out=abnot);
    And(a=b, b=sel, out=ab);
    Or(a=abnot, b=ab, out=out);
}'

STDIN_HDL='output-list a%B3.1.3 b%B3.1.3 sel%B3.1.3 out%B3.1.3;
set a 1, set b 0, set sel 0, eval, output;
set a 1, set b 0, set sel 1, eval, output;'

# Jack: compiled to nand2tetris .vm, driven by a VM-emulator script in stdin.
SRC_JACK='class Main {
    function int addPair(int x, int y) {
        var int a, b, result;
        let a = x;
        let b = y;
        let result = a + b;
        return result;
    }
}'

STDIN_JACK='load Main.vm,

set sp 256,
set local 300,
set argument 400,
set this 3000,
set that 4000,
set argument[0] 11,
set argument[1] 5,

repeat 10 {
vmstep;
}

output-list RAM[0]%D1.6.1 RAM[300]%D1.6.1;
output;'

# Verilog (Icarus 13.0): source = DUT module, stdin = testbench module.
# compile_cmd parse-checks the DUT alone (-tnull); run_cmd does
# `cat > tb.v && iverilog main.v tb.v && vvp` so the testbench from
# stdin lands in the box only at run time. The grep filter strips
# vvp's `tb.v:N: $finish called at T (1s)` epilogue from stdout.
SRC_VERILOG='module inv(input a, output b);
  assign b = ~a;
endmodule'

STDIN_VERILOG='module testbench;
  reg a;
  wire b;
  inv dut(a, b);
  initial begin
    a = 0;
    #1 $display("Hello, Newton!");
    $finish(0);
  end
endmodule'

# Verilog (Icarus 13.0) — self-contained variant: DUT itself contains an
# instantiable top-level module with $display/$finish, and stdin is empty.
# Exercises the run_cmd's `cat > tb.v` path with no input — verifies that
# tb.v ending up zero-byte still lets `iverilog main.v tb.v` elaborate
# cleanly (iverilog tolerates empty source files; the DUT's testbench
# module wins auto-detected top-level since there is nothing else).
SRC_VERILOG_SELF='module testbench;
  initial begin
    $display("Hello, Newton!");
    $finish(0);
  end
endmodule'

# Verilog 3005 — variant with $dumpfile/$dumpvars that drives Phase 3
# asset capture. AND-gate DUT + testbench that produces wave.vcd
# alongside the truth table on stdout. The smoke driver
# (t_stdin_with_asset) verifies both the stdout grading AND that the
# wave.vcd asset shows up via /submissions/:token/assets/wave.vcd.
SRC_VERILOG_WAVE='module and_gate(input wire a, input wire b, output wire y);
  assign y = a & b;
endmodule'

STDIN_VERILOG_WAVE='`timescale 1ns/1ps
module and_gate_tb;
  reg a; reg b; wire y;
  and_gate uut (.a(a), .b(b), .y(y));
  initial begin
    $dumpfile("wave.vcd");
    $dumpvars(0, and_gate_tb);
    a = 0; b = 0; #10;
    a = 0; b = 1; #10;
    a = 1; b = 0; #10;
    a = 1; b = 1; #10;
    $display("Hello, Newton!");
    $finish(0);
  end
endmodule'

SRC_CIRCUITRUN_ARDUINO='void setup() {
  pinMode(13, OUTPUT);
}

void loop() {
  digitalWrite(13, HIGH);
  delay(100);
  digitalWrite(13, LOW);
  delay(100);
}'

STDIN_CIRCUITRUN_ARDUINO='{
  "schema_version": "2026-05-01",
  "scenario": {
    "duration_ms": 1000,
    "stimuli": []
  },
  "checks": [
    {
      "type": "pin-toggled",
      "id": "led-blinks",
      "pin": "D13",
      "min_count": 2
    }
  ],
  "artifacts": {
    "enabled": ["result.json", "waveform.json", "serial.log"]
  },
  "limits": {
    "max_wall_ms": 20000
  },
  "context": {
    "question_id": "judge0-smoke",
    "test_case_id": "arduino-uno-arduino-cpp"
  }
}'

# ────────────────────────────────────────────────────────────────────────
# 0.59 trim: 25 active languages moved to archived.rb (compiler toolchains
# dropped from newtonschool/judge0-newton-compiler:0.27). The "Archived"
# section below documents what's gone; submitting any of those returns a
# 422 "language is archived" from the API.
#
# 0.64 (compilers 0.28): GCC 14 ids 3003/3004 archived; Plain Text (43),
# Kotlin (78), Scala 3 (81) revived for re-introduced course tracks.
# ────────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────────
section "Shell / scripting"
# ────────────────────────────────────────────────────────────────────────
t "Bash 5.2.37 (46)"            46   "$SRC_BASH"
t "Python 3.13.1 (71)"          71   "$SRC_PYTHON"
t "Python 3.12.7 ML (2000)"     2000 "$SRC_PYTHON_ML"
t "Ruby 3.3.6 (72)"             72   "$SRC_RUBY"
t "Node.js 22.11.0 (1999)"      1999 "$SRC_NODE"
t "TypeScript 5.7.2 (74)"       74   "$SRC_TS"
t "R 4.5.2 (80)"                80   "$SRC_R"

# ────────────────────────────────────────────────────────────────────────
section "C / C++"
# ────────────────────────────────────────────────────────────────────────
t "C GCC 9.5 (50)"              50   "$SRC_C"
t "C++ GCC 9.5 (54)"            54   "$SRC_CPP"

# ────────────────────────────────────────────────────────────────────────
section "JVM"
# ────────────────────────────────────────────────────────────────────────
t "Java OpenJDK 21 (62)"        62   "$SRC_JAVA"
t "Kotlin 2.3.21 (78)"          78   "$SRC_KOTLIN"
t "Scala 3.8.3 (81)"            81   "$SRC_SCALA"

# ────────────────────────────────────────────────────────────────────────
section "C# / .NET"
t "C# Mono 6.12.0.122 (3006)"   3006 "$SRC_CSHARP"
t "C# .NET Core 7.0.400 (3007)" 3007 "$SRC_CSHARP"
t "C# .NET Core 8.0.302 (3008)" 3008 "$SRC_CSHARP"

# ────────────────────────────────────────────────────────────────────────
section "Compiled"
# ────────────────────────────────────────────────────────────────────────
t "Go 1.23.4 (60)"              60   "$SRC_GO"
t "Rust 1.83.0 (73)"            73   "$SRC_RUST"

# ────────────────────────────────────────────────────────────────────────
section "SQL"
# ────────────────────────────────────────────────────────────────────────
t "SQLite 3.47.0 (82)"          82   "$SRC_SQL"

# ────────────────────────────────────────────────────────────────────────
section "Plain text"
# ────────────────────────────────────────────────────────────────────────
t "Plain Text (43)"             43   "$SRC_PLAIN_TEXT"

# ────────────────────────────────────────────────────────────────────────
section "Architecture-specific"
# ────────────────────────────────────────────────────────────────────────
case "$ARCH" in
    x86_64|amd64)
        t "NASM 2.16.03 (45)"   45   "$SRC_NASM"
        t "FreeBASIC 1.10.1 (47)" 47 "$SRC_FBC"
        ;;
    aarch64|arm64)
        skip "NASM (45)"        "amd64-only at runtime"
        skip "FreeBASIC (47)"   "amd64-only upstream binary"
        ;;
    *)
        skip "NASM (45)"        "untested arch=$ARCH"
        skip "FreeBASIC (47)"   "untested arch=$ARCH"
        ;;
esac

# ────────────────────────────────────────────────────────────────────────
section "Newton extras"
# ────────────────────────────────────────────────────────────────────────
t "MIPS Mars 4.5 (3001)"        3001 "$SRC_MIPS"

# HDL drives the chip via a .tst-style script in stdin and prints a
# truth-table to stdout. With a=1 b=0 sel=0 → out=1 (selecting a).
t_stdin "HDL Nand2Tetris (3000)"  3000 "$SRC_HDL" "$STDIN_HDL" "|   1   |   0   |   0   |   1   |"

# Jack: source compiles to Main.vm, then a VM-emulator script in stdin
# steps the function call and dumps RAM cells to stdout.
t_stdin "Jack (3002)"           3002 "$SRC_JACK" "$STDIN_JACK" "|    401 |     11 |"

# Verilog: source is the DUT, stdin is the testbench. iverilog parse-checks
# the DUT in compile_cmd; run_cmd does `cat > tb.v` then full-elaborates
# both files and runs vvp. Testbench prints "Hello, Newton!" via $display.
t_stdin "Verilog Icarus 13.0 (3005)" 3005 "$SRC_VERILOG" "$STDIN_VERILOG" "$EXPECTED"

# Verilog empty-stdin: same language id, but DUT is self-contained and
# stdin is empty. `cat > tb.v` produces a zero-byte tb.v; iverilog still
# elaborates cleanly (empty source files are tolerated) and vvp runs the
# DUT's own testbench module. Confirms run_cmd is robust to missing
# testbench, which can happen if the platform UI doesn't populate stdin.
t_stdin "Verilog 3005 self-contained / empty stdin" 3005 "$SRC_VERILOG_SELF" "" "$EXPECTED"

# Verilog with waveform (Phase 3 asset capture). Testbench includes
# $dumpfile + $dumpvars; we expect a wave.vcd asset to be captured and
# surfaced via /submissions/:token/assets/wave.vcd. Adds two PASS
# entries to the smoke summary (stdout grading + asset check).
t_stdin_with_asset "Verilog 3005 with wave.vcd" 3005 \
    "$SRC_VERILOG_WAVE" "$STDIN_VERILOG_WAVE" "$EXPECTED" "wave.vcd"

# CircuitRun: stdin is the testcase payload; source_code is the Arduino sketch.
# The runner prints CIRCUITRUN_EVALUATE_ACCEPTED only after CircuitRun has
# compiled, simulated, verified behavior, and written requested artifacts.
t_stdin_with_asset "CircuitRun Arduino Uno Arduino C++ (3009)" 3009 \
    "$SRC_CIRCUITRUN_ARDUINO" "$STDIN_CIRCUITRUN_ARDUINO" \
    "CIRCUITRUN_EVALUATE_ACCEPTED" "result.json"

# Archived languages are intentionally not tested here — the smoke test
# verifies the *currently active* surface. See db/languages/archived.rb
# for what's been retired (and why).

# ────────────────────────────────────────────────────────────────────────
echo
printf "\033[1mSummary:\033[0m  \033[32m%d passed\033[0m, \033[31m%d failed\033[0m, \033[33m%d skipped\033[0m\n" \
    "$PASS" "$FAIL" "$SKIP"
if (( FAIL > 0 )); then
    echo
    printf "\033[1mFailures:\033[0m\n"
    for f in "${FAILED[@]}"; do printf "  - %s\n" "$f"; done
fi
if (( SKIP > 0 )); then
    echo
    printf "\033[1mSkipped:\033[0m\n"
    for s in "${SKIPPED[@]}"; do printf "  - %s\n" "$s"; done
fi

(( FAIL == 0 ))
